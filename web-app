<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Joudy GPT — Robot Controller</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');

  :root {
    --bg:        #110b18;
    --surface:   #180f28;
    --surface2:  #1f1335;
    --border:    #2e1f58;
    --border2:   #3f2a7a;
    --border-b:  #4a1a38;
    --purple:    #9b5fd4;
    --purple2:   #7c3aed;
    --lavender:  #d4b8f5;
    --lilac:     #c084fc;
    --soft:      #ede0ff;
    --blue:      #ec4899;
    --blue2:     #be185d;
    --blue-dim:  #500724;
    --blue-soft: #f9a8d4;
    --red:       #fb7185;
    --green2:    #6ee7b7;
    --text:      #ddd0f7;
    --dim:       #7268a0;
    --dim2:      #4e4470;
    --glow:      0 0 18px rgba(155,95,212,0.45);
    --glow-sm:   0 0 10px rgba(155,95,212,0.22);
    --glow-b:    0 0 16px rgba(236,72,153,0.38);
    --glow-lg:   0 0 32px rgba(155,95,212,0.55);
  }

  *, *::before, *::after {
    box-sizing: border-box; margin: 0; padding: 0;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
    overscroll-behavior: none;
  }

  body::after {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 3px,
      rgba(181,123,238,0.025) 3px, rgba(181,123,238,0.025) 4px
    );
    pointer-events: none; z-index: 9999;
  }

  header {
    display: flex; align-items: center;
    justify-content: space-between;
    padding: 15px 18px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    position: relative; overflow: hidden;
  }

  header::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), var(--purple), var(--lilac), var(--purple), var(--blue), transparent);
  }

  .logo-wrap { display: flex; flex-direction: column; gap: 1px; }
  .logo { font-family: 'Orbitron', sans-serif; font-size: 18px; font-weight: 900; color: var(--lavender); letter-spacing: 2px; }
  .logo span { color: var(--blue-soft); text-shadow: 0 0 14px rgba(236,72,153,0.55); }
  .logo-sub { font-size: 8px; letter-spacing: 4px; color: var(--dim); text-transform: uppercase; }

  .status { display: flex; align-items: center; gap: 7px; font-size: 9px; letter-spacing: 2px; color: var(--dim); text-transform: uppercase; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); box-shadow: 0 0 6px rgba(244,114,182,0.5); transition: all .4s; }
  .dot.on { background: var(--green2); box-shadow: 0 0 10px rgba(134,239,172,0.7); }

  .connect-bar { padding: 12px 18px; border-bottom: 1px solid var(--border); background: var(--surface); }

  #btnConnect {
    width: 100%; height: 48px;
    background: var(--surface2);
    border: 1px solid var(--purple); border-radius: 10px;
    color: var(--lavender);
    font-family: 'Orbitron', sans-serif;
    font-size: 11px; font-weight: 700; letter-spacing: 3px;
    cursor: pointer; transition: all .2s;
    box-shadow: var(--glow-sm); text-transform: uppercase;
  }
  #btnConnect:active { transform: scale(.97); box-shadow: var(--glow); }
  #btnConnect.on { border-color: var(--green2); color: var(--green2); box-shadow: 0 0 16px rgba(110,231,183,.35); }

  main { padding: 16px 18px; display: flex; flex-direction: column; gap: 18px; max-width: 480px; margin: 0 auto; }

  .section-label {
    font-size: 8px; letter-spacing: 4px; color: var(--blue-soft); margin-bottom: 10px;
    text-transform: uppercase; display: flex; align-items: center; gap: 8px;
  }
  .section-label::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, var(--blue-dim), transparent); }

  .divider { border: none; border-top: 1px solid var(--border); margin: 0; }

  .dpad {
    display: grid;
    grid-template-columns: repeat(3, 78px);
    grid-template-rows: repeat(3, 78px);
    gap: 8px; justify-content: center;
  }

  .dp {
    background: var(--surface2); border: 1px solid var(--border2); border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; cursor: pointer; transition: all .1s;
    color: var(--dim); user-select: none;
  }
  .dp:active, .dp.pressed {
    background: var(--surface); border-color: var(--lilac);
    color: var(--lavender); box-shadow: var(--glow); transform: scale(.9);
  }
  .dp-stop { background: var(--surface2); border-color: var(--blue2); color: var(--blue-soft); font-size: 20px; }
  .dp-stop:active { border-color: var(--blue); box-shadow: var(--glow-b); color: var(--blue-soft); }
  .dp-empty { visibility: hidden; }

  .speed-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 9px; }
  .spd {
    height: 44px; background: var(--surface2); border: 1px solid var(--border); border-radius: 10px;
    color: var(--dim2); font-family: 'Orbitron', sans-serif;
    font-size: 9px; font-weight: 700; letter-spacing: 2px;
    cursor: pointer; transition: all .2s; text-transform: uppercase;
  }
  .spd.active { background: var(--surface); border-color: var(--purple); color: var(--lavender); box-shadow: var(--glow-sm); }
  .spd:active { transform: scale(.93); }

  .face-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 9px; }
  .face {
    height: 68px; background: var(--surface2); border: 1px solid var(--border); border-radius: 14px;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px;
    cursor: pointer; transition: all .15s; user-select: none;
  }
  .face:active { border-color: var(--lilac); box-shadow: var(--glow); transform: scale(.9); }
  .face .e { font-size: 22px; }
  .face .fl { font-size: 7px; color: var(--dim); letter-spacing: 1.5px; text-transform: uppercase; }

  /* ── AUDIO BUTTONS ── */
  .audio-list { display: flex; flex-direction: column; gap: 8px; }
  .aud {
    height: 54px;
    background: var(--surface2);
    border: 1px solid var(--border); border-radius: 10px;
    display: flex; align-items: center; gap: 12px;
    padding: 0 16px; cursor: pointer; transition: all .15s;
    width: 100%; color: var(--text); text-align: left;
    font-family: 'Share Tech Mono', monospace; font-size: 12px;
    user-select: none; position: relative; overflow: hidden;
  }
  .aud:active { border-color: var(--blue); box-shadow: var(--glow-b); transform: scale(.98); }
  .aud.speaking {
    border-color: var(--green2);
    box-shadow: 0 0 14px rgba(110,231,183,0.4);
    animation: pulse-aud 0.6s ease-in-out infinite alternate;
  }
  @keyframes pulse-aud {
    from { box-shadow: 0 0 8px rgba(110,231,183,0.3); }
    to   { box-shadow: 0 0 20px rgba(110,231,183,0.7); }
  }
  .aud .n { color: var(--blue-soft); font-size: 9px; min-width: 22px; font-family: 'Orbitron', sans-serif; font-weight: 700; }
  .aud .ic { font-size: 16px; transition: all .3s; }
  .aud.speaking .ic { animation: spin-ic 0.8s linear infinite; }
  @keyframes spin-ic { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .aud .txt { color: var(--text); font-size: 11px; flex: 1; }
  .aud .vol { font-size: 9px; color: var(--green2); opacity: 0; transition: opacity .3s; }
  .aud.speaking .vol { opacity: 1; }

  /* ── VOICE SETTINGS ── */
  .voice-settings {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 10px; padding: 12px 14px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .voice-row { display: flex; align-items: center; gap: 10px; }
  .voice-lbl { font-size: 9px; color: var(--dim); letter-spacing: 2px; text-transform: uppercase; min-width: 60px; }
  .voice-row input[type=range] {
    flex: 1; accent-color: var(--purple);
    height: 3px; cursor: pointer;
  }
  .voice-val { font-size: 9px; color: var(--lavender); min-width: 32px; text-align: right; }
  .voice-row select {
    flex: 1; background: var(--surface); border: 1px solid var(--border2);
    color: var(--lavender); border-radius: 6px; padding: 4px 8px;
    font-family: 'Share Tech Mono', monospace; font-size: 10px; cursor: pointer;
  }

  .status-card {
    background: var(--surface2); border: 1px solid var(--border2); border-radius: 14px;
    padding: 14px 16px; display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 8px; text-align: center; position: relative; overflow: hidden;
  }
  .status-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--purple2), var(--blue), var(--purple2));
  }
  .stat-item { display: flex; flex-direction: column; gap: 4px; }
  .stat-val { font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 700; color: var(--lavender); }
  .stat-lbl { font-size: 7px; color: var(--blue-soft); letter-spacing: 2px; text-transform: uppercase; }
  .stat-divider { width: 1px; background: var(--border-b); margin: 4px 0; align-self: stretch; }

  .log {
    background: var(--surface2); border: 1px solid var(--border); border-radius: 10px;
    padding: 10px 13px; height: 80px; overflow-y: auto;
    font-size: 9px; color: var(--dim); line-height: 1.8;
    scrollbar-width: thin; scrollbar-color: var(--border2) transparent;
  }
  .log .c { color: var(--blue-soft); }
  .log .e { color: var(--red); }
  .log .s { color: var(--green2); }

  .mk { position: fixed; width: 50px; height: 50px; pointer-events: none; z-index: 100; }
  .mk-tl { top:0; left:0; border-top: 1.5px solid var(--purple); border-left: 1.5px solid var(--purple); opacity: .5; }
  .mk-tr { top:0; right:0; border-top: 1.5px solid var(--blue); border-right: 1.5px solid var(--blue); opacity: .4; }
  .mk-bl { bottom:0; left:0; border-bottom: 1.5px solid var(--blue); border-left: 1.5px solid var(--blue); opacity: .4; }
  .mk-br { bottom:0; right:0; border-bottom: 1.5px solid var(--purple); border-right: 1.5px solid var(--purple); opacity: .5; }

  .robot-header { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 4px 0; }
  .robot-avatar {
    width: 42px; height: 42px; border-radius: 10px; background: var(--surface2);
    border: 1px solid var(--purple); display: flex; align-items: center; justify-content: center;
    font-size: 22px; box-shadow: var(--glow-sm);
  }
  .robot-info { display: flex; flex-direction: column; gap: 2px; }
  .robot-name { font-family: 'Orbitron', sans-serif; font-size: 13px; font-weight: 900; color: var(--lavender); letter-spacing: 1px; }
  .robot-name span { color: var(--blue-soft); }
  .robot-desc { font-size: 8px; color: var(--dim); letter-spacing: 2px; text-transform: uppercase; }
</style>
</head>
<body>

<div class="mk mk-tl"></div>
<div class="mk mk-tr"></div>
<div class="mk mk-bl"></div>
<div class="mk mk-br"></div>

<header>
  <div class="logo-wrap">
    <div class="logo">JOUDY<span> GPT</span></div>
    <div class="logo-sub">autonomous robot controller</div>
  </div>
  <div class="status">
    <div class="dot" id="dot"></div>
    <span id="stxt">offline</span>
  </div>
</header>

<div class="connect-bar">
  <button id="btnConnect" onclick="toggleConnect()">⚡ connect to joudy gpt</button>
</div>

<main>

  <section>
    <div class="robot-header">
      <div class="robot-avatar">🤖</div>
      <div class="robot-info">
        <div class="robot-name">JOUDY <span>GPT</span></div>
        <div class="robot-desc">BLE · LCD Face · RC Mode</div>
      </div>
    </div>
  </section>

  <div class="status-card">
    <div class="stat-item">
      <div class="stat-val" id="stat-spd">MED</div>
      <div class="stat-lbl">Speed</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <div class="stat-val" id="stat-face">IDLE</div>
      <div class="stat-lbl">Face</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <div class="stat-val" id="stat-cmd">—</div>
      <div class="stat-lbl">Last cmd</div>
    </div>
  </div>

  <hr class="divider">

  <!-- D-PAD -->
  <section>
    <div class="section-label">movement</div>
    <div class="dpad">
      <div class="dp-empty"></div>
      <div class="dp" id="dp-F"
        ontouchstart="pressStart('F')" ontouchend="pressEnd()"
        onmousedown="pressStart('F')" onmouseup="pressEnd()">▲</div>
      <div class="dp-empty"></div>

      <div class="dp" id="dp-L"
        ontouchstart="pressStart('L')" ontouchend="pressEnd()"
        onmousedown="pressStart('L')" onmouseup="pressEnd()">◀</div>
      <div class="dp dp-stop" onclick="press('S')">■</div>
      <div class="dp" id="dp-R"
        ontouchstart="pressStart('R')" ontouchend="pressEnd()"
        onmousedown="pressStart('R')" onmouseup="pressEnd()">▶</div>

      <div class="dp-empty"></div>
      <div class="dp" id="dp-B"
        ontouchstart="pressStart('B')" ontouchend="pressEnd()"
        onmousedown="pressStart('B')" onmouseup="pressEnd()">▼</div>
      <div class="dp-empty"></div>
    </div>
  </section>

  <hr class="divider">

  <!-- SPEED -->
  <section>
    <div class="section-label">speed</div>
    <div class="speed-row">
      <button class="spd" id="s1" onclick="setSpd(1)">slow</button>
      <button class="spd active" id="s2" onclick="setSpd(2)">normal</button>
      <button class="spd" id="s3" onclick="setSpd(3)">fast</button>
    </div>
  </section>

  <hr class="divider">

  <!-- FACE -->
  <section>
    <div class="section-label">face expression</div>
    <div class="face-grid">
      <div class="face" onclick="setFace('IDLE')"><span class="e">😐</span><span class="fl">idle</span></div>
      <div class="face" onclick="setFace('HAPPY')"><span class="e">😊</span><span class="fl">happy</span></div>
      <div class="face" onclick="setFace('SAD')"><span class="e">😢</span><span class="fl">sad</span></div>
      <div class="face" onclick="setFace('ANGRY')"><span class="e">😠</span><span class="fl">angry</span></div>
      <div class="face" onclick="setFace('SURPRISED')"><span class="e">😲</span><span class="fl">surprise</span></div>
      <div class="face" onclick="setFace('TALKING')"><span class="e">🗣️</span><span class="fl">talking</span></div>
      <div class="face" onclick="setFace('THINKING')"><span class="e">🤔</span><span class="fl">thinking</span></div>
      <div class="face" onclick="setFace('IDLE')"><span class="e">🔄</span><span class="fl">reset</span></div>
    </div>
  </section>

  <hr class="divider">

  <!-- VOICE LINES -->
  <section>
    <div class="section-label">voice lines</div>

    <!-- Voice settings -->
    <div class="voice-settings" style="margin-bottom:12px;">
      <div class="voice-row">
        <span class="voice-lbl">Voice</span>
        <select id="voiceSelect" onchange="selectVoice()"></select>
      </div>
      <div class="voice-row">
        <span class="voice-lbl">Rate</span>
        <input type="range" id="rateSlider" min="0.5" max="2" step="0.1" value="1"
               oninput="document.getElementById('rateVal').textContent=this.value">
        <span class="voice-val" id="rateVal">1</span>
      </div>
      <div class="voice-row">
        <span class="voice-lbl">Pitch</span>
        <input type="range" id="pitchSlider" min="0" max="2" step="0.1" value="1"
               oninput="document.getElementById('pitchVal').textContent=this.value">
        <span class="voice-val" id="pitchVal">1</span>
      </div>
    </div>

    <div class="audio-list">
      <button class="aud" id="aud1" onclick="playAudio(1, 'Hello! I am Joudy GPT, your robot assistant.')">
        <span class="n">01</span><span class="ic">🔊</span>
        <span class="txt">Hello! I am Joudy GPT.</span>
        <span class="vol">▶ speaking</span>
      </button>
      <button class="aud" id="aud2" onclick="playAudio(2, 'I am ready for the competition. Let us go!')">
        <span class="n">02</span><span class="ic">🔊</span>
        <span class="txt">I am ready for competition.</span>
        <span class="vol">▶ speaking</span>
      </button>
      <button class="aud" id="aud3" onclick="playAudio(3, 'Watch me move! I can navigate any terrain.')">
        <span class="n">03</span><span class="ic">🔊</span>
        <span class="txt">Watch me move!</span>
        <span class="vol">▶ speaking</span>
      </button>
      <button class="aud" id="aud4" onclick="playAudio(4, 'Goodbye! See you next time. It was a pleasure.')">
        <span class="n">04</span><span class="ic">🔊</span>
        <span class="txt">Goodbye! See you next time.</span>
        <span class="vol">▶ speaking</span>
      </button>
      <button class="aud" id="aud5" onclick="playAudio(5, 'I can see you! My sensors are fully active.')">
        <span class="n">05</span><span class="ic">🔊</span>
        <span class="txt">I can see you!</span>
        <span class="vol">▶ speaking</span>
      </button>
    </div>
  </section>

  <hr class="divider">

  <!-- LOG -->
  <section>
    <div class="section-label">command log</div>
    <div class="log" id="log">
      <div class="s">// joudy gpt v4 — open in chrome on android</div>
    </div>
  </section>

</main>

<script>
// ── BLE ───────────────────────────────────────────────────────────────────
const SVC_UUID  = '12345678-1234-1234-1234-123456789abc';
const CHAR_UUID = 'abcdefab-cdef-abcd-efab-cdefabcdefab';

let device = null, server = null, charact = null, connected = false;
let activeBtn = null;

function log(msg, cls='') {
  const box = document.getElementById('log');
  const d = document.createElement('div');
  if (cls) d.className = cls;
  const t = new Date().toLocaleTimeString('en', {hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
  d.textContent = '[' + t + '] ' + msg;
  box.appendChild(d);
  box.scrollTop = box.scrollHeight;
  while (box.children.length > 30) box.firstChild.remove();
}

function setUI(on) {
  connected = on;
  document.getElementById('dot').classList.toggle('on', on);
  document.getElementById('stxt').textContent = on ? 'online' : 'offline';
  const b = document.getElementById('btnConnect');
  b.textContent = on ? '✕ disconnect' : '⚡ connect to joudy gpt';
  b.classList.toggle('on', on);
}

function updateStatCmd(c) {
  document.getElementById('stat-cmd').textContent = c.length > 6 ? c.slice(0,6) : c;
}

async function toggleConnect() {
  if (connected) { disconnect(); return; }
  if (!navigator.bluetooth) {
    alert('Open this page in Google Chrome on Android.\nSafari and Firefox do not support Web Bluetooth.');
    log('Web Bluetooth not available.', 'e'); return;
  }
  try {
    log('Scanning for AI_ROBOT...');
    device = await navigator.bluetooth.requestDevice({
      filters: [{ name: 'AI_ROBOT' }],
      optionalServices: [SVC_UUID]
    });
    device.addEventListener('gattserverdisconnected', () => {
      setUI(false); charact = null;
      log('Connection lost.', 'e');
    });
    log('Connecting...');
    server  = await device.gatt.connect();
    const svc = await server.getPrimaryService(SVC_UUID);
    charact = await svc.getCharacteristic(CHAR_UUID);
    setUI(true);
    log('Connected to ' + device.name + ' ✓', 's');
  } catch(e) {
    log('Failed: ' + e.message, 'e');
  }
}

function disconnect() {
  if (device?.gatt?.connected) device.gatt.disconnect();
  setUI(false);
  log('Disconnected.', 'e');
}

async function cmd(c) {
  if (!connected || !charact) { log('Not connected: ' + c, 'e'); return; }
  try {
    await charact.writeValue(new TextEncoder().encode(c));
    log('→ ' + c, 'c');
    updateStatCmd(c);
  } catch(e) {
    log('Send error: ' + e.message, 'e');
  }
}

function pressStart(c) {
  activeBtn = c;
  const el = document.getElementById('dp-' + c);
  if (el) el.classList.add('pressed');
  cmd(c);
}

function pressEnd() {
  if (activeBtn) {
    const el = document.getElementById('dp-' + activeBtn);
    if (el) el.classList.remove('pressed');
    activeBtn = null;
  }
  cmd('S');
}

function press(c) { cmd(c); }

const SPD_LABELS = { 1: 'LOW', 2: 'MED', 3: 'HIGH' };

function setSpd(n) {
  ['s1','s2','s3'].forEach((id,i) =>
    document.getElementById(id).classList.toggle('active', i+1===n)
  );
  document.getElementById('stat-spd').textContent = SPD_LABELS[n];
  cmd('SPD:' + n);
}

function setFace(f) {
  document.getElementById('stat-face').textContent = f.slice(0,7);
  cmd('FACE:' + f);
}

// ── SPEECH SYNTHESIS ──────────────────────────────────────────────────────
let voices = [];
let selectedVoice = null;
let currentAudBtn = null;

// Load available voices — Chrome loads them asynchronously
function loadVoices() {
  voices = window.speechSynthesis.getVoices();
  const sel = document.getElementById('voiceSelect');
  sel.innerHTML = '';

  // Prefer English voices, put them first
  const english = voices.filter(v => v.lang.startsWith('en'));
  const others  = voices.filter(v => !v.lang.startsWith('en'));
  const sorted  = [...english, ...others];

  sorted.forEach((v, i) => {
    const opt = document.createElement('option');
    opt.value = i;
    opt.textContent = v.name + ' (' + v.lang + ')';
    // Default: prefer a female English voice for robot feel
    if (v.name.toLowerCase().includes('female') || v.name.toLowerCase().includes('samantha') || v.name.toLowerCase().includes('google uk')) {
      opt.selected = true;
      selectedVoice = v;
    }
    sel.appendChild(opt);
  });

  // Fallback: pick first English voice
  if (!selectedVoice && english.length > 0) {
    selectedVoice = english[0];
    sel.selectedIndex = 0;
  }
}

function selectVoice() {
  const idx = document.getElementById('voiceSelect').value;
  const english = voices.filter(v => v.lang.startsWith('en'));
  const others  = voices.filter(v => !v.lang.startsWith('en'));
  const sorted  = [...english, ...others];
  selectedVoice = sorted[idx];
}

// Load voices on page load and when Chrome fires the event
window.speechSynthesis.onvoiceschanged = loadVoices;
loadVoices();

function playAudio(trackNum, text) {
  // Stop any currently speaking audio
  window.speechSynthesis.cancel();

  // Clear previous speaking state
  if (currentAudBtn) {
    currentAudBtn.classList.remove('speaking');
    currentAudBtn = null;
  }

  // Set button to speaking state
  const btn = document.getElementById('aud' + trackNum);
  btn.classList.add('speaking');
  currentAudBtn = btn;

  // Send BLE command to robot (changes LCD face to TALKING)
  cmd('AUDIO:' + trackNum);
  document.getElementById('stat-face').textContent = 'TALK';

  // Create speech utterance
  const utt = new SpeechSynthesisUtterance(text);

  // Apply selected voice
  if (selectedVoice) utt.voice = selectedVoice;

  // Apply rate and pitch from sliders
  utt.rate  = parseFloat(document.getElementById('rateSlider').value);
  utt.pitch = parseFloat(document.getElementById('pitchSlider').value);
  utt.volume = 1.0;

  // When speech ends — remove speaking state
  utt.onend = () => {
    btn.classList.remove('speaking');
    if (currentAudBtn === btn) currentAudBtn = null;
    log('Audio ' + trackNum + ' finished.', 's');
  };

  utt.onerror = (e) => {
    btn.classList.remove('speaking');
    if (currentAudBtn === btn) currentAudBtn = null;
    log('Speech error: ' + e.error, 'e');
  };

  log('🔊 Speaking track ' + trackNum, 's');
  window.speechSynthesis.speak(utt);
}

// Touch prevention for d-pad
document.querySelectorAll('.dp').forEach(el => {
  el.addEventListener('touchstart', e => e.preventDefault(), {passive:false});
  el.addEventListener('touchend',   e => e.preventDefault(), {passive:false});
});

// Chrome Android bug: speech synthesis pauses after ~15 seconds
// This keepalive prevents it from cutting off long phrases
setInterval(() => {
  if (window.speechSynthesis.speaking) {
    window.speechSynthesis.pause();
    window.speechSynthesis.resume();
  }
}, 10000);
</script>
